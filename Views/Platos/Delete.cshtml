@model GastroMatch.Admin.Models.Plato

@{
    ViewData["Title"] = "Eliminar Plato";
}

<h1>Eliminar Plato</h1>

<h3 class="text-danger">¿Estás seguro de que deseas eliminar este plato?</h3>

<div class="card mt-3">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Nombre)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Nombre)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Precio)</dt>
            <dd class="col-sm-9">@Model.Precio.ToString("C2")</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Calorias)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Calorias)</dd>

            <dt class="col-sm-3">Restaurante</dt>
            <dd class="col-sm-9">@Model.Restaurante?.Nombre</dd>

            <dt class="col-sm-3">Categoría</dt>
            <dd class="col-sm-9">@Model.Restaurante?.Categoria?.Nombre</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Eliminar" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
